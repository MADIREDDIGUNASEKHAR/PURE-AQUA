{
  "buildCommand": "npm run build",
  "outputDirectory": "client/build",
  "rewrites": [
    {
      "source": "/api/products",
      "destination": "/api/products"
    },
    {
      "source": "/api/enquiry",
      "destination": "/api/enquiry"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
